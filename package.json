{
  "name": "fedlex-mcp",
  "version": "1.0.0",
  "description": "MCP server for Swiss federal legislation via Fedlex (fedlex.data.admin.ch)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fedlex-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "ingest": "tsx scripts/ingest.ts",
    "drift": "tsx scripts/drift.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "node-html-parser": "^7.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
